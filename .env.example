# Skarion CRM v2.0 Environment Variables
# Copy this file to .env and fill in your actual values.

# === DATABASE ===
# PostgreSQL connection string. For local dev: postgresql://postgres:postgres@localhost:5432/skarion
# For production (Neon): postgresql://user:password@host.neon.tech:5432/skarion?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skarion

# === AUTH ===
# JWT secret for signing tokens. MUST be at least 32 characters in production. Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
# Token expiry time (e.g., 7d, 1h, 30m)
JWT_EXPIRES_IN=7d

# === SERVER ===
# Port the backend server listens on
PORT=4000
# development | production | staging
NODE_ENV=development
# Public URL of the frontend (for CORS, emails, redirects). In production: https://your-frontend.pages.dev
APP_URL=http://localhost:5173
# Public URL of the backend API. In production: https://your-backend.railway.app
API_URL=http://localhost:4000

# === RATE LIMITING ===
# API rate limit window in milliseconds.
RATE_LIMIT_WINDOW_MS=60000
# General per-client/procedure requests per window.
RATE_LIMIT_MAX=300
# Lower limit for sensitive auth/chat/key-test procedures.
SENSITIVE_RATE_LIMIT_MAX=30

# === SUPABASE (optional file storage) ===
# Only needed if STORAGE_PROVIDER=supabase
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# === AI ===
# Never commit real values for any of these — this file is a template only.
# OpenAI API key for AI features. Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxx
# OpenAI model to use (gpt-4o, gpt-4o-mini, gpt-4-turbo, etc.)
OPENAI_MODEL=gpt-4o
# Alternative: Kimi/Moonshot (OpenAI-compatible). Used if OPENAI_API_KEY is empty.
KIMI_API_KEY=sk-kimi-xxxxxxxx
KIMI_BASE_URL=https://api.moonshot.cn/v1
# Alternative: Ollama local AI endpoint. Used if neither of the above is set.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Required to add/replace/decrypt admin-managed AI provider keys (Settings -> AI Providers).
# Generate with: openssl rand -base64 32
AI_KEYS_ENCRYPTION_SECRET=

# === EMAIL ===
# Resend API key for sending emails. Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Sender email address (must be a verified domain in Resend)
FROM_EMAIL=noreply@skarion.com

# === FILE STORAGE ===
# Provider: 'supabase' or 'local'
STORAGE_PROVIDER=local
# If using local storage, the path where uploads are saved (relative to server root)
LOCAL_STORAGE_PATH=./uploads

# === CLOUDFLARE (optional) ===
# Cloudflare API token for DNS/SSL management if needed
CLOUDFLARE_API_TOKEN=

# === RAILWAY / RENDER / FLY.IO ===
# These are typically injected by the platform; no need to set them locally unless testing.
# RAILWAY_ENVIRONMENT_NAME=
# RAILWAY_SERVICE_NAME=
# FLY_APP_NAME=
# RENDER_EXTERNAL_URL=
