{
  "name": "skarion-crm",
  "version": "2.0.0",
  "description": "Skarion CRM - One-Stop Financial Recordkeeping, Taxation, Compliance & W2 Solution",
  "private": true,
  "workspaces": [
    "server",
    "client",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd server && npm run build",
    "build:client": "cd client && npm run build",
    "start": "cd server && npm run start",
    "db:generate": "cd server && npx drizzle-kit generate",
    "db:migrate": "cd server && npx drizzle-kit migrate",
    "db:studio": "cd server && npx drizzle-kit studio",
    "db:seed": "cd server && npx tsx src/db/seed.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run test --workspace=server"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.12.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
